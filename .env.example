# Copy this file to .env and fill in your values. Never commit .env.
#
# See the Appendix (book/Appendix A - Running the Examples.md) for full setup
# instructions with Ollama (free, local), Groq (free cloud), or OpenAI.

# --- Option 1: Ollama (free, runs locally) ---
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# MODEL_NAME=qwen2.5:7b

# --- Option 2: Groq (free cloud tier) ---
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_API_KEY=gsk_your-groq-key-here
# MODEL_NAME=llama-3.1-8b-instant

# --- Option 3: OpenAI (paid) ---
OPENAI_API_KEY=sk-your-key-here
# MODEL_NAME=gpt-4o-mini
